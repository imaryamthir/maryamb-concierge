# Copy this file to `.env` and fill in your key. NEVER commit the real .env.
# (The competition rules explicitly forbid committing API keys.)

# --- Option A: Google AI Studio (simplest) ---------------------------------
GOOGLE_API_KEY=your_google_ai_studio_key_here

# --- Option B: Vertex AI (uncomment to use instead of Option A) -------------
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override the model used by all agents.
# LAYLA_MODEL=gemini-2.5-flash
